# Rust
target/
**/*.rs.bk
Cargo.lock.bak

# DevFlow worktrees (managed by git worktree, not committed)
.claude/worktrees/

# DevFlow tracking files (per-feature, committed with feature branch)
# devflow/<feature>/state.json is committed per-branch

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Local config / secrets
.env
.env.local
config.local.toml
config-test-*.toml
sign-result.json

# Fetch consumer runtime data
data/

# Test fixtures (large binary recordings)
tests/fixtures/*.bin
tests/fixtures/*.pcap

# Superpowers SDD scratch (task briefs/reports, ledger)
.superpowers/
